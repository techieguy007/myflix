{
  "taskName": "MyFlixLocalStreaming",
  "server": {
    "host": "0.0.0.0",
    "port": 5000,
    "nodeEnv": "production"
  },
  "media": {
    "root": "D:\\movies",
    "autoScanOnStart": true,
    "scanDelayMs": 2500,
    "minFileSizeMB": 1,
    "minDurationMinutes": 15,
    "renameMode": "suggest"
  },
  "metadata": {
    "provider": "omdb",
    "enabled": true,
    "omdbApiKey": "",
    "omdbApiKeys": [],
    "maxRequestsPerScan": 25
  },
  "transcoding": {
    "ffmpegPath": "C:\\ProgramData\\chocolatey\\lib\\ffmpeg\\tools\\ffmpeg\\bin\\ffmpeg.exe",
    "ffprobePath": "C:\\ProgramData\\chocolatey\\lib\\ffmpeg\\tools\\ffmpeg\\bin\\ffprobe.exe",
    "ffmpegThreads": 2,
    "ffmpegPreset": "ultrafast",
    "realtime": true,
    "prepareOnStartup": false,
    "preparedMaxStartupJobs": 0
  },
  "service": {
    "nodeExe": "C:\\Program Files\\nodejs\\node.exe",
    "logDirectory": "logs",
    "logLevel": "info",
    "openBrowserOnStart": false,
    "stopExistingOnPort": false
  }
}
